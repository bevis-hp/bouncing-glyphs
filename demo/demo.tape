Output demo/demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 1200
Set Height 650
Set Framerate 30
Set WindowBar Colorful
Set Padding 10

# Start the animation
Type "glyphfall --count 12"
Enter
Sleep 5s

# Spawn more glyphs interactively
Space
Sleep 1200ms
Space
Sleep 1200ms
Space
Sleep 1000ms
Space
Sleep 1000ms
Space
Sleep 1000ms
Space
Sleep 1200ms
Space
Sleep 3s

# Quit
Type "q"
Sleep 500ms
